{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Chandra": {
    "VllmApiBase": "http://localhost:8000/v1",
    "VllmApiKey": "EMPTY",
    "VllmModelName": "chandra",
    "MaxOutputTokens": 12384,
    "MaxVllmRetries": 6
  },
  "Api": {
    "MaxPages": 50,
    "RequestTimeoutSeconds": 600,
    "MaxUploadBytes": 104857600,
    "IncludeImages": true,
    "AllowedCorsOrigins": []
  },
  "Auth": {
    "ApiKeys": [],
    "BypassPaths": [ "/health", "/openapi", "/swagger" ]
  }
}
